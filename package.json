{
  "name": "@ryangarber/ai-sdk-antigravity-proxy",
  "version": "0.1.2",
  "description": "Antigravity proxy for AI SDK.",
  "author": "Ryan Garber",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RyanGarber/ai-sdk-antigravity-proxy.git"
  },
  "homepage": "https://github.com/RyanGarber/ai-sdk-antigravity-proxy#readme",
  "bugs": {
    "url": "https://github.com/RyanGarber/ai-sdk-antigravity-proxy/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "prepublishOnly": "pnpm run lint && pnpm run typecheck && pnpm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.10",
    "@commander-js/extra-typings": "^15.0.0",
    "commander": "^15.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "antigravity-proxy": "link:antigravity-proxy",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "ai": "^6.0.208",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
